{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Extensions.Http": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "System.Net.Http.HttpClient.TikTokApi": "Warning"
    }
  },
  "TikTokShop": {
    "ApiBaseUrl": "https://open-api.tiktokglobalshop.com",
    "AuthBaseUrl": "https://auth.tiktok-shops.com",
    "TokenExchangePath": "/api/token/getAccessToken",
    "TokenRefreshPath": "/api/token/refreshToken",
    "AppKey": "",
    "AppSecret": "",
    "AccessToken": "",
    "RefreshToken": "",
    "ShopId": "",
    "PollIntervalSeconds": 30,
    "OrderLookbackMinutes": 90,
    "PageSize": 50,
    "AutoRefreshAccessToken": true,
    "RefreshEarlyMinutes": 10
  },
  "Printing": {
    "Enabled": true,
    "PrinterName": "",
    "SaveArtifacts": true,
    "PaperWidthCharacters": 42,
    "PaperSize": "100x150",
    "CustomPaperWidthMm": 100,
    "CustomPaperHeightMm": 150,
    "MarginMm": 2.5,
    "BaseFontSize": 8.6,
    "MinFontSize": 6.3,
    "AutoPrintNewOrders": false,
    "AutoPrintAfterBridgeCapture": false,
    "ShowBuyerAccountName": true,
    "ShowBuyerPlatformUserId": true,
    "ShowBuyerName": true,
    "ShowBuyerEmail": false,
    "ShowRecipientPhone": true,
    "ShowBuyerMessage": true,
    "ShowOrderAmounts": true,
    "ShowSku": false,
    "ShowPaidTime": true,
    "ShowCreatedTime": true
  },
  "AppData": {
    "StateFilePath": "Data/runtime-state.json",
    "PrintJobDirectory": "Data/print-jobs"
  },
  "AllowedHosts": "*"
}

